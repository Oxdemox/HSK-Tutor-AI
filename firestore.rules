rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - name: string (optional)
    //   - createdAt: timestamp (optional)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "yassine.kheder.1994@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create or update user roles.
      // A user can create their own profile initially if it's not an admin role.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      
      allow delete: if isAdmin();
    }

    match /users/{userId}/quiz_progress/{hskLevel} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/progress/{hskLevel} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/history/{hskLevel} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/starred_words/{wordId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
